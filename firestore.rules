rules_version = '2';

// Firestore security rules for dansk-app.
// Paste the contents of this file into:
//   Firebase Console → Firestore Database → Rules
// Then click "Publish".
//
// Guarantees:
//   - Only authenticated users can read or write.
//   - Each user can only read or write their OWN progress document.
//   - No user can enumerate or read other users' data.

service cloud.firestore {
  match /databases/{database}/documents {

    // /users/{uid}/progress/data  — the single document per user where
    // js/progress.js mirrors local progress (study, quiz, flashcards, streaks).
    match /users/{userId}/progress/{docId} {
      allow read, write: if request.auth != null
                        && request.auth.uid == userId;
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
